# ---- Telegram ----
# 从 @BotFather /newbot 获取
BOT_TOKEN=123456:ABC-DEF...

# ---- 公网 HTTPS 域名 (cloudflared/ngrok)，Mini App 登录页用 ----
PUBLIC_BASE_URL=https://your-tunnel.trycloudflare.com

# ---- LLM (aigc-gateway, OpenAI 兼容 REST) ----
# 默认便宜够用；难 case 可切 qwen3.5-plus / kimi-k2.5 / claude-opus-4.7
LLM_MODEL=deepseek-v3
AIGC_BASE_URL=https://aigc.guangai.ai/v1
AIGC_API_KEY=pk_...

# ---- 瑞幸环境: prod | test03 | pre ----
LUCKIN_ENV=prod

# ---- Token 加密密钥 (Fernet) ----
# 生成: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=

# ---- SQLite 路径 ----
DB_PATH=coffee.db

# ---- 安全护栏 ----
# 单用户单日消费上限 (元)；超过则拒绝 createOrder
DAILY_SPEND_LIMIT=100

# ---- 渠道服务 (微信桥接 service/app.py) ----
# bridge 与 service 之间的共享密钥；留空则不校验（仅当 service 绑定 127.0.0.1 时可接受）
BRIDGE_SECRET=

# ---- 微信主动回推端点 (bridge 入站 /push)，登录/定位/领券成功回推用 ----
# 形如 http://127.0.0.1:8300；留空则微信侧不回推（优雅跳过）。bridge 已实现 /push（监听 127.0.0.1:PUSH_PORT，默认 8300）。
WECHAT_PUSH_URL=
# bridge /push 监听端口（可选，默认 8300）；与 WECHAT_PUSH_URL 的端口一致即可。
PUSH_PORT=8300

# ---- 语音转写 (云 ASR；网关无 ASR，必须外接；需 ffmpeg) ----
# ASR_PROVIDER 留空=关闭语音。dashscope(阿里,单key) / tencent(腾讯) / iflytek(讯飞)
ASR_PROVIDER=
ASR_API_KEY=        # 阿里 DashScope 单 key
ASR_APP_ID=         # 讯飞 APPID / 腾讯 SecretId
ASR_API_SECRET=     # 讯飞 APISecret / 腾讯 SecretKey

# ---- 地理编码 (高德 Web 服务 key) ----
# 用于把「地址/地名」转成 GCJ-02 经纬度（微信渠道 /loc 地址）。
# 免费注册：https://lbs.amap.com → 应用管理 → 新建应用 → 添加 Key → 服务平台选「Web服务」
AMAP_KEY=
